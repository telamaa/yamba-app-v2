<!doctype html>
<html lang="fr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <meta http-equiv="x-ua-compatible" content="ie=edge" />
    <title>Réinitialisation du mot de passe - Yamba</title>
    <style>
      @media (max-width: 620px) {
        .container { width: 100% !important; }
        .px { padding-left: 16px !important; padding-right: 16px !important; }
        .hero { padding: 22px 16px !important; }
        .otp { letter-spacing: 6px !important; font-size: 28px !important; }
        .btn { display:block !important; width:100% !important; }
      }
    </style>
</head>

<body style="margin:0;padding:0;background:#f4f6fb;color:#111827;font-family:Arial,Helvetica,sans-serif;">
<!-- Préheader (invisible dans le mail mais visible en aperçu) -->
<div style="display:none;max-height:0;overflow:hidden;opacity:0;color:transparent;">
    Code de réinitialisation Yamba : <%= otp %>
</div>

<table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0" style="background:#f4f6fb;">
    <tr>
        <td align="center" style="padding:24px 12px;">
            <!-- Container -->
            <table role="presentation" class="container" width="600" cellspacing="0" cellpadding="0" border="0"
                   style="width:600px;max-width:600px;background:#ffffff;border-radius:16px;overflow:hidden;box-shadow:0 6px 24px rgba(17,24,39,0.08);">

                <!-- Header / Hero -->
                <tr>
                    <td class="hero" style="padding:28px 24px;background:linear-gradient(135deg,#0ea5e9 0%, #2563eb 55%, #7c3aed 100%);">
                        <table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0">
                            <tr>
                                <td style="vertical-align:middle;">
                                    <div style="font-size:18px;font-weight:700;letter-spacing:0.3px;color:#ffffff;">
                                        Yamba
                                    </div>
                                    <div style="margin-top:6px;font-size:14px;opacity:0.95;color:#e0f2fe;">
                                        Réinitialisation du mot de passe
                                    </div>
                                </td>
                                <td align="right" style="vertical-align:middle;">
                                    <!-- Logo (remplace l'URL par ton image) -->
                                    <img
                                            src="https://via.placeholder.com/96x40.png?text=Yamba"
                                            width="96"
                                            height="40"
                                            alt="Yamba"
                                            style="display:block;border:0;outline:none;text-decoration:none;border-radius:8px;background:#ffffff;"
                                    />
                                </td>
                            </tr>
                        </table>

                        <!-- Image hero (remplace l'URL par ton visuel) -->
                        <div style="margin-top:18px;">
                            <img
                                    src="https://via.placeholder.com/552x180.png?text=Password+Reset"
                                    width="552"
                                    alt="Yamba - Password reset"
                                    style="display:block;width:100%;max-width:552px;height:auto;border-radius:12px;border:0;outline:none;text-decoration:none;"
                            />
                        </div>
                    </td>
                </tr>

                <!-- Body -->
                <tr>
                    <td class="px" style="padding:24px 24px 8px 24px;">
                        <h1 style="margin:0 0 10px 0;font-size:22px;line-height:1.25;color:#111827;">
                            Code de réinitialisation
                        </h1>

                        <p style="margin:0 0 16px 0;font-size:15px;line-height:1.6;color:#374151;">
                            Bonjour <strong><%= typeof firstName !== 'undefined' ? firstName : name %></strong>,<br/>
                            Nous avons reçu une demande de réinitialisation du mot de passe de votre compte Yamba.
                            Pour continuer, saisissez le code ci-dessous :
                        </p>

                        <!-- OTP Card -->
                        <table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0" style="margin:10px 0 18px 0;">
                            <tr>
                                <td align="center" style="padding:18px;background:#f3f4f6;border:1px solid #e5e7eb;border-radius:12px;">
                                    <div class="otp" style="font-size:32px;font-weight:800;letter-spacing:10px;color:#111827;">
                                        <%= otp %>
                                    </div>
                                    <div style="margin-top:8px;font-size:13px;color:#6b7280;">
                                        Valable 5 minutes
                                    </div>
                                </td>
                            </tr>
                        </table>

                        <p style="margin:0 0 16px 0;font-size:14px;line-height:1.6;color:#374151;">
                            Si vous n’êtes pas à l’origine de cette demande, vous pouvez ignorer ce message.
                            Aucun changement ne sera effectué sans ce code.
                        </p>

                        <!-- Tips -->
                        <table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0" style="margin:0 0 16px 0;">
                            <tr>
                                <td style="padding:14px;border-radius:12px;background:#eff6ff;border:1px solid #dbeafe;">
                                    <div style="font-size:13px;color:#1f2937;">
                                        <strong>Conseil sécurité :</strong> ne partagez jamais votre code OTP, même avec le support.
                                    </div>
                                </td>
                            </tr>
                        </table>

                        <!-- Warning -->
                        <table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0" style="margin:0 0 18px 0;">
                            <tr>
                                <td style="padding:14px;border-radius:12px;background:#fffbeb;border:1px solid #fde68a;">
                                    <div style="font-size:13px;color:#1f2937;">
                                        <strong>Important :</strong> si vous recevez plusieurs emails de ce type sans être à l’origine de la demande,
                                        nous vous recommandons de changer votre mot de passe dès que possible et de contacter le support.
                                    </div>
                                </td>
                            </tr>
                        </table>

                    </td>
                </tr>

                <!-- Footer -->
                <tr>
                    <td class="px" style="padding:14px 24px 24px 24px;background:#fafafa;border-top:1px solid #f1f5f9;">
                        <p style="margin:0 0 8px 0;font-size:12px;line-height:1.6;color:#6b7280;">
                            Besoin d’aide ? Contactez-nous : <a href="mailto:support@yamba.com" style="color:#2563eb;text-decoration:none;">support@yamba.com</a>
                        </p>
                        <p style="margin:0;font-size:12px;line-height:1.6;color:#9ca3af;">
                            © <%= new Date().getFullYear() %> Yamba. Tous droits réservés.
                        </p>
                    </td>
                </tr>

            </table>
            <!-- /Container -->
        </td>
    </tr>
</table>
</body>
</html>
