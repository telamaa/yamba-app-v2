generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────
// USER
// ─────────────────────────────────────────────

model User {
  id              String    @id @default(auto()) @map("_id") @db.ObjectId
  firstName       String
  lastName        String
  email           String
  emailNormalized String    @unique
  passwordHash    String?
  phoneNumber     String?
  country         String
  phoneE164       String?
  gender          Gender
  birthDate       DateTime?
  roles           Role[]    @default([SHIPPER])

  // Carrier onboarding
  carrierStatus CarrierStatus @default(NONE)

  // Relations
  avatar         Image?          @relation("UserAvatar")
  carrierPage    CarrierPage?
  addresses      Address[]
  trips          Trip[]          @relation("UserTrips")
  carrierReviews CarrierReview[]

  // Lifecycle
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  isDeleted Boolean   @default(false)
  deletedAt DateTime?

  @@index([carrierStatus])
  @@index([roles])
  @@index([phoneE164])
}

// ─────────────────────────────────────────────
// CARRIER PAGE (affiché "Espace Tripper" en UI)
// ─────────────────────────────────────────────

model CarrierPage {
  id     String @id @default(auto()) @map("_id") @db.ObjectId
  userId String @unique @db.ObjectId
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Profil public
  name        String
  bio         String?
  address     String?
  phoneE164   String?
  avatar      Image?  @relation("CarrierAvatar")
  coverUrl    String?
  socialLinks Json[]  @default([])

  // Onboarding tracking
  onboardingStep OnboardingStep @default(PROFILE)

  // Stripe Connect
  stripeAccountId          String?
  stripeOnboardingComplete Boolean @default(false)
  stripeChargesEnabled     Boolean @default(false)
  stripePayoutsEnabled     Boolean @default(false)

  // Badges
  isVerified     Boolean @default(false)
  isSuperCarrier Boolean @default(false)

  // Stats (mis à jour via triggers/cron)
  totalTripsPublished Int   @default(0)
  totalParcelsCarried Int   @default(0)
  totalTripsCancelled Int   @default(0)
  ratingsAvg          Float @default(0)
  ratingsCount        Int   @default(0)

  // Relations
  reviews CarrierReview[]
  trips   Trip[]

  // Rappels onboarding
  lastReminderSentAt DateTime?
  reminderCount      Int       @default(0)

  // Lifecycle
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([stripeAccountId])
  @@index([isVerified])
  @@index([isSuperCarrier])
  @@index([ratingsAvg])
}

// ─────────────────────────────────────────────
// CARRIER REVIEWS
// ─────────────────────────────────────────────

model CarrierReview {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  carrierPageId String      @db.ObjectId
  carrierPage   CarrierPage @relation(fields: [carrierPageId], references: [id], onDelete: Cascade)

  userId String @db.ObjectId
  user   User   @relation(fields: [userId], references: [id])

  rating  Float
  comment String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([carrierPageId])
  @@index([userId])
  @@index([carrierPageId, rating])
}

// ─────────────────────────────────────────────
// IMAGE
// ─────────────────────────────────────────────

model Image {
  id     String @id @default(auto()) @map("_id") @db.ObjectId
  fileId String
  url    String

  userId String? @unique @db.ObjectId
  user   User?   @relation("UserAvatar", fields: [userId], references: [id], onDelete: Cascade)

  carrierPageId String?      @unique @db.ObjectId
  carrierPage   CarrierPage? @relation("CarrierAvatar", fields: [carrierPageId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─────────────────────────────────────────────
// ADDRESS
// ─────────────────────────────────────────────

model Address {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  userId        String   @db.ObjectId
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  label         String?
  recipientName String?
  phoneE164     String?
  streetLine1   String
  streetLine2   String?
  city          String
  region        String?
  postalCode    String
  country       String
  isArchived    Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([userId])
  @@index([userId, isArchived])
}

// ─────────────────────────────────────────────
// TRIP
// ─────────────────────────────────────────────

type TripCategoryCondition {
  category         ParcelCategory
  priceAmountCents Int
  handoffMoments   CategoryHandoffMoment[]
  pickupMoments    PickupMoment[]
}

model Trip {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  userId String @db.ObjectId
  user   User   @relation("UserTrips", fields: [userId], references: [id], onDelete: Cascade)

  carrierPageId String?      @db.ObjectId
  carrierPage   CarrierPage? @relation(fields: [carrierPageId], references: [id])

  status      TripStatus @default(DRAFT)
  currentStep Int        @default(1)

  transportMode TransportMode?
  tripType      TripType       @default(ONE_WAY)

  originLabel      String?
  destinationLabel String?

  originPlaceId String?
  originCity    String?
  originRegion  String?
  originCountry String?
  originLat     Float?
  originLng     Float?

  destinationPlaceId String?
  destinationCity    String?
  destinationRegion  String?
  destinationCountry String?
  destinationLat     Float?
  destinationLng     Float?

  departureDateLocal String?
  arrivalDateLocal   String?
  departureTimeLocal String?
  arrivalTimeLocal   String?

  departureAt DateTime?
  arrivalAt   DateTime?

  returnDepartureAt DateTime?
  returnArrivalAt   DateTime?

  flightType         FlightType?
  trainTripType      TrainTripType?
  carTripFlexibility CarTripFlexibility?

  flightLayoverCities String[] @default([])
  trainStopCities     String[] @default([])

  travelReference String?

  acceptedCategories ParcelCategory[]        @default([])
  categoryConditions TripCategoryCondition[]

  handDeliveryOnly Boolean @default(false)
  instantBooking   Boolean @default(false)

  ticketVerificationStatus TicketVerificationStatus @default(NOT_SUBMITTED)

  currencyCode String @default("EUR")

  notes String?

  documents TripDocument[]

  publishedAt DateTime?
  cancelledAt DateTime?
  archivedAt  DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([carrierPageId])
  @@index([status])
  @@index([transportMode])
  @@index([departureAt])
  @@index([publishedAt])
  @@index([userId, status])
  @@index([transportMode, status, departureAt])
  @@index([originPlaceId])
  @@index([destinationPlaceId])
}

model TripDocument {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  tripId String @db.ObjectId
  trip   Trip   @relation(fields: [tripId], references: [id], onDelete: Cascade)

  uploadedByUserId String? @db.ObjectId

  type   TripDocumentType
  status TripDocumentStatus @default(PENDING)

  fileId       String
  url          String
  originalName String?
  mimeType     String?
  sizeBytes    Int?

  title       String?
  description String?

  verifiedAt      DateTime?
  rejectedAt      DateTime?
  rejectionReason String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tripId])
  @@index([tripId, type])
  @@index([status])
}

// ─────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum Role {
  SHIPPER
  CARRIER
  ADMIN
}

enum CarrierStatus {
  NONE
  ONBOARDING
  ACTIVE
  SUSPENDED
}

enum OnboardingStep {
  PROFILE
  STRIPE
  COMPLETE
}

enum TripStatus {
  DRAFT
  PUBLISHED
  PAUSED
  COMPLETED
  CANCELLED
  ARCHIVED
}

enum TripType {
  ONE_WAY
  ROUND_TRIP
}

enum TransportMode {
  PLANE
  TRAIN
  CAR
}

enum FlightType {
  DIRECT
  WITH_LAYOVER
}

enum TrainTripType {
  DIRECT
  WITH_CONNECTION
  WITH_INTERMEDIATE_STOPS
}

enum CarTripFlexibility {
  DIRECT
  DETOUR_BY_AGREEMENT
}

enum ParcelCategory {
  CLOTHES
  SHOES
  FASHION_ACCESSORIES
  OTHER_ACCESSORIES
  BOOKS
  DOCUMENTS
  SMALL_TOYS
  PHONE
  COMPUTER
  OTHER_ELECTRONICS
  CHECKED_BAG_23KG
  CABIN_BAG_12KG
}

enum CategoryHandoffMoment {
  BEFORE_DEPARTURE
  AT_DEPARTURE
}

enum PickupMoment {
  ON_ARRIVAL
  LATER_AT_ADDRESS
}

enum TicketVerificationStatus {
  NOT_SUBMITTED
  PENDING
  VERIFIED
  REJECTED
}

enum TripDocumentType {
  TICKET_PROOF
  ITINERARY_PROOF
  VEHICLE_PROOF
  IDENTITY_PROOF
  OTHER
}

enum TripDocumentStatus {
  PENDING
  VERIFIED
  REJECTED
}
