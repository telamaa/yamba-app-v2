generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────
// USER
// ─────────────────────────────────────────────

model User {
  id              String    @id @default(auto()) @map("_id") @db.ObjectId
  firstName       String
  lastName        String
  email           String
  emailNormalized String    @unique
  passwordHash    String?
  phoneNumber     String?
  phoneE164       String?
  gender          Gender?
  birthDate       DateTime?
  roles           Role[]    @default([SHIPPER])

  // Slug public unique pour la page profil /u/[slug]
  publicSlug String? @unique

  // Stats shipper (notes reçues en tant qu'expéditeur)
  shipperRatingsAvg   Float @default(0)
  shipperRatingsCount Int   @default(0)
  parcelsSentCount    Int   @default(0)

  // Carrier onboarding
  carrierStatus CarrierStatus @default(NONE)

  // Relations
  avatar      Image?       @relation("UserAvatar")
  carrierPage CarrierPage?
  addresses   Address[]
  trips       Trip[]       @relation("UserTrips")

  // MODIFIÉ — Reviews unifiées (remplace carrierReviews CarrierReview[])
  reviewsReceived Review[] @relation("ReviewSubject")
  reviewsGiven    Review[] @relation("ReviewAuthor")

  // Système de follow
  following UserFollow[] @relation("UserFollowing") // les users que je suis
  followers UserFollow[] @relation("UserFollowers") // les users qui me suivent

  // Alertes de route (Wishlist routes)
  savedRoutes SavedRoute[]

  consentLogs ConsentLog[]

  // Lifecycle
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  isDeleted Boolean   @default(false)
  deletedAt DateTime?

  @@index([carrierStatus])
  @@index([roles])
  @@index([phoneE164])
}

// ─────────────────────────────────────────────
// CONSENT LOG (RGPD - traçabilité du consentement)
// ─────────────────────────────────────────────

model ConsentLog {
  id     String @id @default(auto()) @map("_id") @db.ObjectId
  userId String @db.ObjectId
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  type       ConsentType
  version    String
  acceptedAt DateTime    @default(now())

  ipAddress String?
  userAgent String?
  locale    String?

  revokedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([userId, type])
  @@index([userId, type, acceptedAt])
  @@index([type, version])
}

// ─────────────────────────────────────────────
// CARRIER PAGE (affiché "Espace Tripper" en UI)
// ─────────────────────────────────────────────

model CarrierPage {
  id     String @id @default(auto()) @map("_id") @db.ObjectId
  userId String @unique @db.ObjectId
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Profil public
  name        String
  bio         String? // ← Inchangé : bio spécifique tripper
  phoneE164   String?
  avatar      Image?  @relation("CarrierAvatar")
  coverUrl    String?
  socialLinks Json[]  @default([])

  // Localisation publique
  primaryAddressId String?  @unique @db.ObjectId
  primaryAddress   Address? @relation("CarrierPrimaryAddress", fields: [primaryAddressId], references: [id])

  // Onboarding tracking
  onboardingStep OnboardingStep @default(PROFILE)

  // Stripe Connect
  stripeAccountId          String?
  stripeOnboardingComplete Boolean @default(false)
  stripeChargesEnabled     Boolean @default(false)
  stripePayoutsEnabled     Boolean @default(false)

  // Badges
  isVerified     Boolean @default(false)
  isSuperCarrier Boolean @default(false)

  // Stats carrier
  totalTripsPublished Int   @default(0)
  totalParcelsCarried Int   @default(0)
  totalTripsCancelled Int   @default(0)
  ratingsAvg          Float @default(0)
  ratingsCount        Int   @default(0)

  // Relations
  // SUPPRIMÉ — reviews CarrierReview[] (accessible via user.reviewsReceived avec kind=AS_CARRIER)
  trips Trip[]

  // Rappels onboarding
  lastReminderSentAt DateTime?
  reminderCount      Int       @default(0)

  // Lifecycle
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([stripeAccountId])
  @@index([isVerified])
  @@index([isSuperCarrier])
  @@index([ratingsAvg])
}

// ─────────────────────────────────────────────
// REVIEW (anciennement CarrierReview, unifié)
// ─────────────────────────────────────────────

model Review {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  // Qui est noté
  subjectUserId String @db.ObjectId
  subjectUser   User   @relation("ReviewSubject", fields: [subjectUserId], references: [id], onDelete: Cascade)

  // Qui note
  authorUserId String @db.ObjectId
  authorUser   User   @relation("ReviewAuthor", fields: [authorUserId], references: [id], onDelete: Cascade)

  // Le subject est noté en tant que tripper ou shipper
  kind ReviewKind

  // Lien vers la booking (futur, pour empêcher les fake reviews)
  bookingId String? @db.ObjectId

  rating  Float
  comment String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([subjectUserId])
  @@index([authorUserId])
  @@index([subjectUserId, kind])
  @@index([subjectUserId, kind, createdAt])
}

// ─────────────────────────────────────────────
// USER FOLLOW (système de suivi)
// ─────────────────────────────────────────────

model UserFollow {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  // Qui suit
  followerId String @db.ObjectId
  follower   User   @relation("UserFollowing", fields: [followerId], references: [id], onDelete: Cascade)

  // Qui est suivi
  followedId String @db.ObjectId
  followed   User   @relation("UserFollowers", fields: [followedId], references: [id], onDelete: Cascade)

  // Préférences de notification pour ce suivi
  notifyNextTrip Boolean @default(true)

  createdAt DateTime @default(now())

  @@unique([followerId, followedId]) // empêche les doublons
  @@index([followerId])
  @@index([followedId])
}

// ─────────────────────────────────────────────
// SAVED ROUTE (alertes de route)
// ─────────────────────────────────────────────
// L'utilisateur sauvegarde une intention de voyage ("Paris → Brazzaville en
// juin"). Quand un Tripper publie un trajet qui match, on lui envoie un email.
//
// Matching intelligent :
//   - Score 100 : nom de ville identique (case-insensitive) OU placeId identique
//   - Score 70  : même pays + distance < 50km (haversine) — "trajet proche"
//   - Score < 70 : pas notifié
//
// Cycle de vie :
//   - expiresAt = latestDate + 1j  (si dates fournies)
//   - expiresAt = createdAt + 6 mois (sinon)
//   - Cron quotidien : warn à J-7, désactive à J
// ─────────────────────────────────────────────

model SavedRoute {
  id     String @id @default(auto()) @map("_id") @db.ObjectId
  userId String @db.ObjectId
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // ─── Origine (snapshot Google Places) ───
  originCity        String
  originCountry     String
  originCountryCode String // ISO 2 letters (ex: "FR")
  originPlaceId     String?
  originLat         Float?
  originLng         Float?

  // ─── Destination (snapshot Google Places) ───
  destinationCity        String
  destinationCountry     String
  destinationCountryCode String
  destinationPlaceId     String?
  destinationLat         Float?
  destinationLng         Float?

  // ─── Période (optionnelle) ───
  earliestDate DateTime?
  latestDate   DateTime?

  // ─── Préférences notif ───
  emailEnabled  Boolean @default(true)
  inAppEnabled  Boolean @default(false) // pour V2
  includeNearby Boolean @default(true) // toggle "trajets proches" (score 70)

  // ─── Cycle de vie ───
  expiresAt           DateTime // calculé à create/update
  expiryWarningSentAt DateTime? // anti-spam relance
  isActive            Boolean   @default(true)

  // ─── Anti-spam runtime ───
  lastNotifiedAt DateTime? // dernière notif émise

  // ─── Métadonnées ───
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, isActive])
  @@index([originCountryCode, destinationCountryCode, isActive])
  @@index([expiresAt, isActive])
}

// ─────────────────────────────────────────────
// IMAGE
// ─────────────────────────────────────────────

model Image {
  id     String @id @default(auto()) @map("_id") @db.ObjectId
  fileId String
  url    String

  userId String? @unique @db.ObjectId
  user   User?   @relation("UserAvatar", fields: [userId], references: [id], onDelete: Cascade)

  carrierPageId String?      @unique @db.ObjectId
  carrierPage   CarrierPage? @relation("CarrierAvatar", fields: [carrierPageId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─────────────────────────────────────────────
// ADDRESS
// ─────────────────────────────────────────────

model Address {
  id     String @id @default(auto()) @map("_id") @db.ObjectId
  userId String @db.ObjectId
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  label String?

  formattedAddress String?
  placeId          String?
  lat              Float?
  lng              Float?

  streetLine1 String?
  streetLine2 String?
  city        String?
  region      String?
  postalCode  String?
  country     String?
  countryCode String?

  recipientName String?
  phoneE164     String?

  isArchived Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  carrierPage CarrierPage? @relation("CarrierPrimaryAddress")

  @@index([userId])
  @@index([userId, isArchived])
  @@index([placeId])
  @@index([city])
  @@index([country])
  @@index([countryCode])
}

// ─────────────────────────────────────────────
// TRIP
// ─────────────────────────────────────────────

type TripCategoryCondition {
  category         ParcelCategory
  priceAmountCents Int
  handoffMoments   CategoryHandoffMoment[]
  pickupMoments    PickupMoment[]
}

model Trip {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  userId String @db.ObjectId
  user   User   @relation("UserTrips", fields: [userId], references: [id], onDelete: Cascade)

  carrierPageId String?      @db.ObjectId
  carrierPage   CarrierPage? @relation(fields: [carrierPageId], references: [id])

  status      TripStatus @default(DRAFT)
  currentStep Int        @default(1)

  transportMode TransportMode?
  tripType      TripType       @default(ONE_WAY)

  // ─── Origin ──────────────────────────────────────
  originLabel    String?
  originPlaceId  String?
  originCity     String?
  originCityCode String?
  originRegion   String?
  originCountry  String?
  originLat      Float?
  originLng      Float?
  originTimezone String?

  // ─── Destination ─────────────────────────────────
  destinationLabel    String?
  destinationPlaceId  String?
  destinationCity     String?
  destinationCityCode String?
  destinationRegion   String?
  destinationCountry  String?
  destinationLat      Float?
  destinationLng      Float?
  destinationTimezone String?

  // ─── Dates ───────────────────────────────────────
  departureDateLocal String?
  arrivalDateLocal   String?
  departureTimeLocal String?
  arrivalTimeLocal   String?

  departureAt DateTime?
  arrivalAt   DateTime?

  returnDepartureAt DateTime?
  returnArrivalAt   DateTime?

  departureHourLocal Int?

  // ─── Mode-specific ───────────────────────────────
  flightType         FlightType?
  trainTripType      TrainTripType?
  carTripFlexibility CarTripFlexibility?

  flightLayoverCities String[] @default([])
  trainStopCities     String[] @default([])

  travelReference String?

  // ─── Conditions / pricing ────────────────────────
  acceptedCategories ParcelCategory[]        @default([])
  categoryConditions TripCategoryCondition[]

  handDeliveryOnly Boolean @default(false)
  instantBooking   Boolean @default(false)

  minPriceCents Int?

  carrierRatingSnapshot Float?

  ticketVerificationStatus TicketVerificationStatus @default(NOT_SUBMITTED)

  currencyCode String @default("EUR")

  // ─── Capacité ────────────────────────────────────
  maxSlots    Int?
  bookedSlots Int  @default(0)

  notes String?

  documents TripDocument[]

  publishedAt DateTime?
  cancelledAt DateTime?
  archivedAt  DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // ─── Indexes ─────────────────────────────────────
  @@index([userId])
  @@index([carrierPageId])
  @@index([status])
  @@index([transportMode])
  @@index([departureAt])
  @@index([publishedAt])
  @@index([userId, status])
  @@index([originPlaceId])
  @@index([destinationPlaceId])
  @@index([status, departureAt, transportMode])
  @@index([minPriceCents])
  @@index([carrierRatingSnapshot])
  @@index([departureHourLocal])
  @@index([originCity])
  @@index([destinationCity])
}

model TripDocument {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  tripId String @db.ObjectId
  trip   Trip   @relation(fields: [tripId], references: [id], onDelete: Cascade)

  uploadedByUserId String? @db.ObjectId

  type   TripDocumentType
  status TripDocumentStatus @default(PENDING)

  fileId       String
  url          String
  originalName String?
  mimeType     String?
  sizeBytes    Int?

  title       String?
  description String?

  verifiedAt      DateTime?
  rejectedAt      DateTime?
  rejectionReason String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tripId])
  @@index([tripId, type])
  @@index([status])
}

// ─────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum ConsentType {
  TERMS
  PRIVACY
  COOKIES
  MARKETING
}

enum Role {
  SHIPPER
  CARRIER
  ADMIN
}

enum CarrierStatus {
  NONE
  ONBOARDING
  ACTIVE
  SUSPENDED
}

enum OnboardingStep {
  PROFILE
  STRIPE
  COMPLETE
}

enum TripStatus {
  DRAFT
  PUBLISHED
  PAUSED
  COMPLETED
  CANCELLED
  ARCHIVED
}

enum TripType {
  ONE_WAY
  ROUND_TRIP
}

enum TransportMode {
  PLANE
  TRAIN
  CAR
}

enum FlightType {
  DIRECT
  WITH_LAYOVER
}

enum TrainTripType {
  DIRECT
  WITH_CONNECTION
  WITH_INTERMEDIATE_STOPS
}

enum CarTripFlexibility {
  DIRECT
  DETOUR_BY_AGREEMENT
}

enum ParcelCategory {
  CLOTHES
  SHOES
  FASHION_ACCESSORIES
  OTHER_ACCESSORIES
  BOOKS
  DOCUMENTS
  SMALL_TOYS
  PHONE
  COMPUTER
  OTHER_ELECTRONICS
  CHECKED_BAG_23KG
  CABIN_BAG_12KG
}

enum CategoryHandoffMoment {
  BEFORE_DEPARTURE
  AT_DEPARTURE
}

enum PickupMoment {
  ON_ARRIVAL
  LATER_AT_ADDRESS
}

enum TicketVerificationStatus {
  NOT_SUBMITTED
  PENDING
  VERIFIED
  REJECTED
}

enum TripDocumentType {
  TICKET_PROOF
  ITINERARY_PROOF
  VEHICLE_PROOF
  IDENTITY_PROOF
  OTHER
}

enum TripDocumentStatus {
  PENDING
  VERIFIED
  REJECTED
}

//  Type de review
enum ReviewKind {
  AS_CARRIER // Le subject a été noté en tant que tripper
  AS_SHIPPER // Le subject a été noté en tant qu'expéditeur
}

model SiteConfig {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  logo   String?
  banner String?

  commissionRate Float @default(0.10)

  maxDocSizeMb   Int @default(5)
  maxDocsPerTrip Int @default(5)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
