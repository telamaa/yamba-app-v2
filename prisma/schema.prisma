generator client {
  provider = "prisma-client-js"
  // output   = "../generated/prisma"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model User {
  id              String          @id @default(auto()) @map("_id") @db.ObjectId
  firstName       String
  lastName        String
  email           String
  emailNormalized String          @unique
  passwordHash    String?
  phoneNumber     String?
  phoneE164       String?
  gender          Gender
  birthDate       DateTime?
  roles           Role[]          @default([SHIPPER])
  carrierStatus   CarriersStatus  @default(NONE)
  carrierProfile  CarrierProfile?
  avatar          Image?          @relation("UserAvatar")
  addresses       Address[]
  trips           Trip[]          @relation("UserTrips")
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@index([carrierStatus])
  @@index([roles])
  @@index([phoneE164])
}

model Image {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  fileId    String
  url       String
  userId    String   @unique @db.ObjectId
  user      User     @relation("UserAvatar", fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Address {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  userId        String   @db.ObjectId
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  label         String?
  recipientName String?
  phoneE164     String?
  streetLine1   String
  streetLine2   String?
  city          String
  region        String?
  postalCode    String
  country       String
  isArchived    Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([userId])
  @@index([userId, isArchived])
}

model CarrierProfile {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @unique @db.ObjectId
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  shopName  String?
  country   String
  phoneE164 String?
  kycStatus String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([country])
}

/**
 * Conditions définies par catégorie sélectionnée
 */
type TripCategoryCondition {
  category         ParcelCategory
  priceAmountCents Int
  handoffMoments   CategoryHandoffMoment[]
  pickupMoments    PickupMoment[]
}

model Trip {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  userId String @db.ObjectId
  user   User   @relation("UserTrips", fields: [userId], references: [id], onDelete: Cascade)

  // Workflow
  status      TripStatus @default(DRAFT)
  currentStep Int        @default(1)

  // Base annonce
  transportMode TransportMode?
  tripType      TripType       @default(ONE_WAY)

  // Itinéraire saisi (raw / front)
  originLabel      String?
  destinationLabel String?

  // Données enrichies système / géocodage plus tard
  originPlaceId String?
  originCity    String?
  originRegion  String?
  originCountry String?
  originLat     Float?
  originLng     Float?

  destinationPlaceId String?
  destinationCity    String?
  destinationRegion  String?
  destinationCountry String?
  destinationLat     Float?
  destinationLng     Float?

  // Saisie actuelle du front
  departureDateLocal String?
  arrivalDateLocal   String?
  departureTimeLocal String?
  arrivalTimeLocal   String?

  // Champs normalisés calculés / système
  departureAt DateTime?
  arrivalAt   DateTime?

  // Aller-retour éventuel pour plus tard
  returnDepartureAt DateTime?
  returnArrivalAt   DateTime?

  // Détails selon mode de transport
  flightType         FlightType?
  trainTripType      TrainTripType?
  carTripFlexibility CarTripFlexibility?

  // Escales / correspondances
  flightLayoverCities String[] @default([])
  trainStopCities     String[] @default([])

  // Référence voyage
  travelReference String?

  // Catégories acceptées
  acceptedCategories ParcelCategory[]        @default([])
  categoryConditions TripCategoryCondition[]

  // Options complémentaires réellement pilotées par le front actuel
  handDeliveryOnly Boolean @default(false)
  instantBooking   Boolean @default(false)

  // Vérification document / billet / justificatif
  ticketVerificationStatus TicketVerificationStatus @default(NOT_SUBMITTED)

  // Devise
  currencyCode String @default("EUR")

  // Notes libres
  notes String?

  // Relations
  documents TripDocument[]

  // Cycle de vie
  publishedAt DateTime?
  cancelledAt DateTime?
  archivedAt  DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([status])
  @@index([transportMode])
  @@index([departureAt])
  @@index([publishedAt])
  @@index([userId, status])
  @@index([transportMode, status, departureAt])
  @@index([originPlaceId])
  @@index([destinationPlaceId])
}

model TripDocument {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  tripId String @db.ObjectId
  trip   Trip   @relation(fields: [tripId], references: [id], onDelete: Cascade)

  uploadedByUserId String? @db.ObjectId

  type   TripDocumentType
  status TripDocumentStatus @default(PENDING)

  fileId       String
  url          String
  originalName String?
  mimeType     String?
  sizeBytes    Int?

  title       String?
  description String?

  verifiedAt      DateTime?
  rejectedAt      DateTime?
  rejectionReason String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tripId])
  @@index([tripId, type])
  @@index([status])
}

