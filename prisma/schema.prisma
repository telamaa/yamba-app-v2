enum Gender {
  MALE
  FEMALE
  OTHER
}

enum Role {
  SHIPPER
  CARRIER
  ADMIN
}

enum CarriersStatus {
  NONE
  PENDING
  APPROVED
  SUSPENDED
}

enum TripStatus {
  DRAFT
  PUBLISHED
  PAUSED
  COMPLETED
  CANCELLED
  ARCHIVED
}

enum TripType {
  ONE_WAY
  ROUND_TRIP
}

enum TransportMode {
  PLANE
  TRAIN
  CAR
}

enum FlightType {
  DIRECT
  WITH_LAYOVER
}

enum TrainTripType {
  DIRECT
  WITH_CONNECTION
  WITH_INTERMEDIATE_STOPS
}

enum CarTripFlexibility {
  DIRECT
  DETOUR_BY_AGREEMENT
}

enum ParcelCategory {
  CLOTHES
  SHOES
  FASHION_ACCESSORIES
  OTHER_ACCESSORIES
  BOOKS
  DOCUMENTS
  SMALL_TOYS
  PHONE
  COMPUTER
  OTHER_ELECTRONICS
  CHECKED_BAG_23KG
  CABIN_BAG_12KG
}

enum CategoryHandoffMoment {
  BEFORE_DEPARTURE
  AT_DEPARTURE
}

enum PickupMoment {
  ON_ARRIVAL
  LATER_AT_ADDRESS
}

enum TicketVerificationStatus {
  NOT_SUBMITTED
  PENDING
  VERIFIED
  REJECTED
}

enum TripDocumentType {
  TICKET_PROOF
  ITINERARY_PROOF
  VEHICLE_PROOF
  IDENTITY_PROOF
  OTHER
}

enum TripDocumentStatus {
  PENDING
  VERIFIED
  REJECTED
}
